{
  "name": "symphony-pi",
  "version": "0.0.0",
  "description": "A long-running automation service that polls issue trackers and runs pi-coding-agent sessions",
  "homepage": "https://github.com/d-kimuson/symphony-pi#readme",
  "bugs": {
    "url": "https://github.com/d-kimuson/symphony-pi/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-kimuson/symphony-pi"
  },
  "bin": {
    "symphony-pi": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node ./dist/cli.mjs start",
    "dev": "run-p 'dev:*'",
    "dev:server": "SYMPHONY_RUNTIME=dev node --watch src/server/main.ts",
    "dev:web": "vite",
    "build": "run-s build:server build:web",
    "build:server": "tsdown",
    "build:web": "vite build",
    "typecheck": "tsgo -p . --noEmit",
    "lint": "run-p lint:*",
    "lint:oxlint": "oxlint --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "lint:oxfmt": "pnpm fix:oxfmt --check",
    "fix": "run-p fix:*",
    "fix:oxlint": "pnpm lint:oxlint --fix",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "node scripts/prepare.ts",
    "prepack": "run-s build",
    "release": "node scripts/release.ts",
    "check:bundled-licenses": "node scripts/check-bundled-licenses.ts",
    "smoke:pack": "run-s build smoke:pack:check",
    "smoke:pack:check": "node src/scripts/smoke-packed-package.ts"
  },
  "dependencies": {
    "nanoid": "5.1.11"
  },
  "devDependencies": {
    "@base-ui/react": "1.4.1",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@fontsource-variable/geist": "5.2.9",
    "@hono/node-server": "2.0.2",
    "@octokit/rest": "22.0.1",
    "@sinclair/typebox": "0.34.49",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router": "1.170.4",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260517.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "changelogithub": "14.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "gatecheck": "0.0.1",
    "get-port": "7.2.0",
    "hono": "4.12.19",
    "inquirer": "13.4.2",
    "lefthook": "2.1.6",
    "liquidjs": "10.27.0",
    "lucide-react": "1.16.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "1.60.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "4.7.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tsdown": "0.22.0",
    "tw-animate-css": "1.4.0",
    "valibot": "1.4.0",
    "vite": "8.0.13",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
